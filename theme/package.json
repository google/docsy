{
  "name": "@docsy/theme",
  "version": "0.15.1-dev+041-over-main-4d8d85ef",
  "description": "A Hugo theme for technical documentation sites",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/google/docsy.git",
    "directory": "theme"
  },
  "homepage": "https://www.docsy.dev",
  "bugs": "https://github.com/google/docsy/issues",
  "license": "Apache-2.0",
  "keywords": [
    "hugo",
    "hugo-theme",
    "documentation",
    "technical-documentation",
    "docsy"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "gen-favicons": "scripts/gen-favicons/cli.mjs"
  },
  "files": [
    "assets",
    "hugo.yaml",
    "i18n",
    "layouts",
    "scripts/gen-favicons/cli.mjs",
    "scripts/gen-favicons/index.mjs",
    "scripts/gen-favicons/README.md",
    "static"
  ],
  "scripts": {
    "update:dep": "npm install --save-exact @fortawesome/fontawesome-free@latest bootstrap@latest",
    "update:packages": "npx npm-check-updates -x @fortawesome/fontawesome-free -u "
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "6.7.2",
    "bootstrap": "5.3.8"
  }
}
